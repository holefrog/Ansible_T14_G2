# ==========================================
# 1. 远程云服务器 (VPS)
# ==========================================
Host myvps
    HostName 198.51.100.25               # 服务器的真实 IP 或域名
    User root                            # 登录用户名
    Port 2222                            # 如果修改了默认端口，可在此指定
    IdentityFile ~/.ssh/id_ed25519_vps   # 指定该主机使用的专属私钥

# ==========================================
# 2. 局域网开发板 / 媒体服务器
# ==========================================
Host pi
    HostName 192.168.50.115              # 局域网 IP
    User pi                              # 对应的用户名
    IdentityFile ~/.ssh/id_ed25519_pi

# ==========================================
# 3. 代码托管平台
# ==========================================
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_github
    IdentitiesOnly yes                   # 强制只使用指定的密钥，防止 SSH 尝试代理中其他密钥导致 "Too many authentication failures" 报错

# ==========================================
# 4. 全局默认配置 (务必放在文件最末尾)
# ==========================================
Host *
    ServerAliveInterval 60               # 每 60 秒发送一次心跳包，防止 SSH 长时间无操作断开
    AddKeysToAgent yes                   # 自动将使用的密钥加入 ssh-agent
